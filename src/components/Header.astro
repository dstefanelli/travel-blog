---
import { SITE_TITLE } from "../consts";
import type { AppLang } from "../lib/locale";
import { resolveLang, withRouteLangPrefix } from "../lib/locale";
import HeaderLink from "./HeaderLink.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

type Props = {
  lang?: AppLang;
};

const { lang: providedLang } = Astro.props;
const lang =
  providedLang ??
  resolveLang(Astro.url, Astro.request.headers.get("accept-language"));
const withLang = (path: string) => withRouteLangPrefix(path, lang);
---

<header
  class="m-0 bg-white px-4 py-1.5 shadow-[0_2px_8px_rgba(var(--black),0.05)] max-[720px]:px-[0.8rem] max-[720px]:py-[0.35rem]"
>
  <nav
    class="flex min-h-14 items-center justify-between gap-4"
    aria-label="Principal"
  >
    <h2 class="m-0 text-2xl">
      <a class="text-[rgb(var(--gray-dark))] no-underline" href={withLang("/")}
        >{SITE_TITLE}</a
      >
    </h2>

    <div class="flex items-center gap-2 max-[720px]:hidden">
      <HeaderLink
        class="border-b-[3px] border-b-transparent px-[0.7rem] py-[0.6rem] leading-none text-[rgb(var(--gray-dark))] no-underline [&.active]:border-b-(--accent) [&.active]:no-underline"
        href={withLang("/")}
      >
        Home
      </HeaderLink>
      <HeaderLink
        class="border-b-[3px] border-b-transparent px-[0.7rem] py-[0.6rem] leading-none text-[rgb(var(--gray-dark))] no-underline [&.active]:border-b-(--accent) [&.active]:no-underline"
        href={withLang("/blog/")}
      >
        Blog
      </HeaderLink>
      <div class="flex items-center">
        <LanguageSwitcher lang={lang} />
      </div>
    </div>

    <button
      class="hidden cursor-pointer items-center justify-center rounded-full border border-[rgb(var(--gray-light))] bg-white px-[0.85rem] py-[0.55rem] text-[0.85rem] leading-none font-bold text-[rgb(var(--gray-dark))] max-[720px]:inline-flex"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
    >
      <span aria-hidden="true">Menu</span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="border-t border-t-[rgb(var(--gray-light))] pb-3 pt-2 max-[720px]:grid max-[720px]:gap-2"
    hidden
  >
    <HeaderLink
      class="border-b-2 border-b-transparent py-2 leading-none text-[rgb(var(--gray-dark))] no-underline [&.active]:border-b-[var(--accent)] [&.active]:no-underline"
      href={withLang("/")}
    >
      Home
    </HeaderLink>
    <HeaderLink
      class="border-b-2 border-b-transparent py-2 leading-none text-[rgb(var(--gray-dark))] no-underline [&.active]:border-b-[var(--accent)] [&.active]:no-underline"
      href={withLang("/blog/")}
    >
      Blog
    </HeaderLink>
    <div class="flex items-center">
      <LanguageSwitcher lang={lang} />
    </div>
  </div>
</header>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const mobileMenu = document.querySelector<HTMLElement>("#mobile-menu");
  const breakpoint = window.matchMedia("(min-width: 721px)");

  const closeMenu = () => {
    if (!menuButton || !mobileMenu) return;
    menuButton.setAttribute("aria-expanded", "false");
    menuButton.setAttribute("aria-label", "Abrir menú de navegación");
    mobileMenu.hidden = true;
  };

  menuButton?.addEventListener("click", () => {
    if (!mobileMenu || !menuButton) return;
    const isOpen = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", String(!isOpen));
    menuButton.setAttribute(
      "aria-label",
      isOpen ? "Abrir menú de navegación" : "Cerrar menú de navegación",
    );
    mobileMenu.hidden = isOpen;
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  breakpoint.addEventListener("change", (event) => {
    if (event.matches) closeMenu();
  });
</script>
