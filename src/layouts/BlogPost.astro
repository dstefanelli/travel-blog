---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { mediaUrl } from "../consts";
import type { PostEntity } from "../types";
import { normalizeLang, type AppLang } from "../lib/locale";

type Props = PostEntity & {
  lang?: string;
};

const {
  title,
  excerpt,
  createdAt,
  travelDate,
  coverImage,
  lang = "es-ES",
} = Astro.props;

const uiLang: AppLang = normalizeLang(lang) ?? "es";

const heroUrl =
  mediaUrl(coverImage?.formats?.large?.url) ??
  mediaUrl(coverImage?.formats?.medium?.url) ??
  mediaUrl(coverImage?.formats?.small?.url) ??
  mediaUrl(coverImage?.url);
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={excerpt ?? ""} />
  </head>

  <body>
    <Header lang={uiLang} />
    <main class="m-0 w-full max-w-full">
      <article>
        <div class="w-full">
          {
            heroUrl && (
              <Image
                class="mx-auto block rounded-xl [box-shadow:var(--box-shadow)]"
                width={1020}
                height={510}
                src={heroUrl}
                alt={coverImage?.alternativeText || title}
              />
            )
          }
        </div>
        <div
          class="prose mx-auto w-[720px] max-w-[calc(100%-2em)] p-4 text-[rgb(var(--gray-dark))]"
        >
          <div class="mb-4 py-4 text-center leading-none">
            <div class="mb-2 text-[rgb(var(--gray))]">
              {
                travelDate && (
                  <div class="italic">
                    Fecha del viaje{" "}
                    <FormattedDate date={new Date(travelDate)} locale={lang} />
                  </div>
                )
              }
            </div>
            <h1 class="text-3xl sm:text-5xl mb-2 mt-0">{title}</h1>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
