---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { normalizeLang, type AppLang } from "../lib/locale";

type Props = {
  title: string;
  description?: string;
  image?: ImageMetadata | string | null;
  lang?: string;
};

const { title, description = "", image, lang = "es-ES" } = Astro.props;
const isLocalImage = image && typeof image !== "string";
const uiLang: AppLang = normalizeLang(lang) ?? "es";
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header lang={uiLang} />
    <main class="m-0 w-full max-w-full">
      <article>
        {
          image && (
            <div class="mx-auto w-full px-4">
              {isLocalImage ? (
                <Image
                  class="mx-auto block h-auto w-[min(1020px,100%)] rounded-xl [box-shadow:var(--box-shadow)]"
                  src={image as ImageMetadata}
                  alt={title}
                />
              ) : (
                <img
                  class="mx-auto block h-auto w-[min(1020px,100%)] rounded-xl [box-shadow:var(--box-shadow)]"
                  src={image as string}
                  alt={title}
                />
              )}
            </div>
          )
        }
        <div
          class="prose mx-auto w-[720px] max-w-[calc(100%-2em)] p-4 text-[rgb(var(--gray-dark))]"
        >
          <div class="mb-4 py-4 text-center leading-[1.1]">
            <h1 class="text-3xl sm:text-5xl mb-2 mt-0">{title}</h1>
            {
              description && (
                <p class="m-0 italic text-[rgb(var(--gray))]">{description}</p>
              )
            }
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
