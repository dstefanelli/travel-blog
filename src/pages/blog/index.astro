---
import { SITE_DESCRIPTION, SITE_TITLE, mediaUrl } from "../../consts";
import type { PostEntity } from "../../types";
import { Image } from "astro:assets";
import { apiGet } from "../../lib/services";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import {
  resolveLang,
  toCmsLocale,
  withRouteLangPrefix,
} from "../../lib/locale";

const page = Number(Astro.url.searchParams.get("page") ?? "1");
const lang = resolveLang(
  Astro.url,
  Astro.request.headers.get("accept-language"),
);
const pageSize = 10;
const fetchPostsByLang = (queryLang: "es" | "de" | "en") =>
  apiGet<PostEntity[]>("/api/posts", {
    "pagination[page]": String(page),
    "pagination[pageSize]": String(pageSize),
    "sort[0]": "travelDate:desc",
    locale: toCmsLocale(queryLang),
    populate: "*",
  });

let response = await fetchPostsByLang(lang);
if (response.data.length === 0 && lang !== "es") {
  response = await fetchPostsByLang("es");
}

const { data, meta } = response;

const pageCount = meta?.pagination?.pageCount ?? 1;
---

<html>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header lang={lang} />
    <main class="w-[960px]">
      <section>
        <h1 class="mb-4 text-center">Últimas Aventuras 🚀</h1>
        <ul
          class="m-0 grid list-none grid-cols-2 gap-8 p-0 max-[720px]:grid-cols-1 max-[720px]:gap-2"
        >
          {
            data.map((p) => (
              <li class="max-[720px]:text-center">
                <a
                  class="group block no-underline transition duration-200 ease-in-out"
                  href={`${withRouteLangPrefix(`/blog/${p.slug}/`, lang)}${
                    p.documentId
                      ? `?doc=${encodeURIComponent(p.documentId)}`
                      : ""
                  }`}
                >
                  {mediaUrl(p.coverImage?.formats?.medium?.url) && (
                    <Image
                      class="mb-2 w-full rounded-xl group-hover:[box-shadow:var(--box-shadow)]"
                      src={mediaUrl(p.coverImage?.formats?.medium?.url)!}
                      alt={p.coverImage?.alternativeText || p.title}
                      width={300}
                      height={200}
                    />
                  )}
                  <h4 class="text-lg m-0 leading-none text-[rgb(var(--black))]">
                    {p.title}
                  </h4>
                  <span class="m-0 text-[rgb(var(--gray))]">
                    <FormattedDate
                      date={
                        p.travelDate
                          ? new Date(p.travelDate)
                          : new Date(p.createdAt)
                      }
                    />
                  </span>
                  {p.excerpt ? (
                    <p class="m-0 leading-tight text-[rgb(var(--black))]">
                      {p.excerpt}
                    </p>
                  ) : null}
                </a>
              </li>
            ))
          }
        </ul>

        <nav class="mt-6 flex gap-3">
          {
            page > 1 ? (
              <a
                href={`${withRouteLangPrefix("/blog/", lang)}?page=${page - 1}`}
              >
                ← Prev
              </a>
            ) : (
              <span />
            )
          }
          <span>Página {page} / {pageCount}</span>
          {
            page < pageCount ? (
              <a
                href={`${withRouteLangPrefix("/blog/", lang)}?page=${page + 1}`}
              >
                Next →
              </a>
            ) : (
              <span />
            )
          }
        </nav>
      </section>
    </main>
    <Footer />
  </body>
</html>
